<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Student Course System</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <header>
        <nav class="navbar">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                🎓 StudentCourse
            </a>
            <div class="nav-links">
                <a asp-controller="Home" asp-action="Index">Dashboard</a>
                <a asp-controller="Students" asp-action="Index">Students</a>
                <a asp-controller="Courses" asp-action="Index">Courses</a>
            </div>
        </nav>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer>
        <p>Student–Course Management System &copy; @DateTime.Now.Year | Built with ASP.NET Core MVC + Dapper</p>
    </footer>
</body>
</html>
