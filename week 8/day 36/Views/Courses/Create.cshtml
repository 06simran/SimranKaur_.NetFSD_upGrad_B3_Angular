@model Course
@{
    ViewData["Title"] = "Add Course";
}

<div class="page-header">
    <h1>➕ Add New Course</h1>
    <a asp-action="Index" class="btn btn-outline">← Back to Courses</a>
</div>

<div class="form-card">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="CourseName">Course Name</label>
            <input asp-for="CourseName" class="form-control" placeholder="e.g. Computer Science" required />
            <span asp-validation-for="CourseName" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Add Course</button>
            <a asp-action="Index" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
