@model Student
@{
    ViewData["Title"] = "Student Details";
}

<div class="page-header">
    <h1>👨‍🎓 Student Details</h1>
    <a asp-action="Index" class="btn btn-outline">← Back to Students</a>
</div>

<div class="detail-card">
    <div class="detail-row">
        <span class="detail-label">Student ID</span>
        <span class="detail-value"><span class="badge">#@Model.StudentId</span></span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Student Name</span>
        <span class="detail-value"><strong>@Model.StudentName</strong></span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Enrolled Course</span>
        <span class="detail-value">
            <span class="course-tag">
                📚 @Model.Course?.CourseName
                <a asp-controller="Courses" asp-action="Details" asp-route-id="@Model.CourseId">(View Course)</a>
            </span>
        </span>
    </div>
    <div class="detail-row">
        <span class="detail-label">Course ID (FK)</span>
        <span class="detail-value"><code>CourseId = @Model.CourseId</code></span>
    </div>
</div>
