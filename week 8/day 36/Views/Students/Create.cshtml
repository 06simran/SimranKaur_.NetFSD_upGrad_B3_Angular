@model Student
@{
    ViewData["Title"] = "Add Student";
}

<div class="page-header">
    <h1>➕ Add New Student</h1>
    <a asp-action="Index" class="btn btn-outline">← Back to Students</a>
</div>

<div class="form-card">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="StudentName">Student Name</label>
            <input asp-for="StudentName" class="form-control" placeholder="Enter student name" required />
            <span asp-validation-for="StudentName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="CourseId">Enroll in Course</label>
            <select asp-for="CourseId" class="form-control" required>
                <option value="">-- Select a Course --</option>
                @foreach (var course in (IEnumerable<StudentCourseSystem.Models.Course>)ViewBag.Courses)
                {
                    <option value="@course.CourseId">@course.CourseName</option>
                }
            </select>
            <span asp-validation-for="CourseId" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Add Student</button>
            <a asp-action="Index" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
