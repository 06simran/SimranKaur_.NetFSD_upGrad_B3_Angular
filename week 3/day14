------------------------------------------------------------
-- PROBLEM 1 (LEVEL 1)
-- REQUIREMENTS:
-- 1. Display product name with model year using CONCAT
-- 2. Show product_name, model_year, list_price
-- 3. Calculate price difference between product price and
--    average price of its category
-- 4. Display only products whose price is greater than the
--    average price of their category
------------------------------------------------------------

SELECT 
CONCAT(p.product_name,' (',p.model_year,')') AS product,
p.product_name,
p.model_year,
p.list_price,
p.list_price - c.avg_price AS price_difference
FROM products p
JOIN (
    SELECT category_id, AVG(list_price) AS avg_price
    FROM products
    GROUP BY category_id
) c
ON p.category_id = c.category_id
WHERE p.list_price > c.avg_price;

