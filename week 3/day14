------------------------------------------------------------
-- PROBLEM 2 (LEVEL 1)
-- REQUIREMENTS:
-- 1. Display full customer name using CONCAT
-- 2. Count total orders placed by each customer
-- 3. Calculate total order value
-- 4. Classify customers using CASE:
--      VIP Customer → total value > 10000
--      Regular Customer → total value <= 10000
--      Inactive Customer → no orders
-- 5. Include customers who have not placed any orders
------------------------------------------------------------

SELECT 
CONCAT(c.first_name,' ',c.last_name) AS customer_name,
COUNT(o.order_id) AS total_orders,
SUM(o.order_value) AS total_value,
CASE
WHEN SUM(o.order_value) > 10000 THEN 'VIP Customer'
WHEN SUM(o.order_value) <= 10000 THEN 'Regular Customer'
ELSE 'Inactive Customer'
END AS status
FROM customers c
LEFT JOIN orders o 
ON c.customer_id = o.customer_id
GROUP BY c.customer_id, c.first_name, c.last_name;

