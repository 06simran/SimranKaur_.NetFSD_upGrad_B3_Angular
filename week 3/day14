------------------------------------------------------------
-- PROBLEM 3 (LEVEL 2)
-- STORE PERFORMANCE AND STOCK VALIDATION
-- REQUIREMENTS:
-- 1. Display store name
-- 2. Display product name
-- 3. Show available stock in each store
-- 4. Calculate total quantity sold
-- 5. Validate stock using CASE:
--      If available stock >= sold quantity → Stock Available
--      Otherwise → Stock Shortage
------------------------------------------------------------

SELECT 
s.store_name,
p.product_name,
st.quantity AS available_stock,
SUM(oi.quantity) AS sold_quantity,
CASE
WHEN st.quantity >= SUM(oi.quantity) THEN 'Stock Available'
ELSE 'Stock Shortage'
END AS stock_status
FROM stores s
JOIN orders o ON s.store_id = o.store_id
JOIN order_items oi ON o.order_id = oi.order_id
JOIN products p ON oi.product_id = p.product_id
JOIN stocks st ON st.product_id = p.product_id 
AND st.store_id = s.store_id
GROUP BY s.store_name, p.product_name, st.quantity;

------------------------------------------------------------
-- PROBLEM 4 (LEVEL 2)
-- STORE SALES PERFORMANCE
-- REQUIREMENTS:
-- 1. Display store name
-- 2. Calculate total quantity of products sold by each store
-- 3. Calculate total revenue generated by each store
-- 4. Use JOIN between stores, orders, order_items, and products
-- 5. Group results by store
------------------------------------------------------------

SELECT 
    s.store_name,
    SUM(oi.quantity) AS total_products_sold,
    SUM(oi.quantity * p.list_price) AS total_revenue
FROM stores s
JOIN orders o 
    ON s.store_id = o.store_id
JOIN order_items oi 
    ON o.order_id = oi.order_id
JOIN products p 
    ON oi.product_id = p.product_id
GROUP BY s.store_name;