@model WebApplication4.Models.ContactInfo

<h2>Search Contact By ID</h2>

<form asp-action="Search" method="get">

    <div class="mb-3">
        <label asp-for="ContactId"></label>
        <input asp-for="ContactId" name="id" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Search</button>
</form>

<hr />

@if (Model != null)
{
    <h4>Contact Details</h4>

    <p><strong>ID:</strong> @Model.ContactId</p>
    <p><strong>Name:</strong> @Model.FirstName @Model.LastName</p>
    <p><strong>Company:</strong> @Model.CompanyName</p>
    <p><strong>Email:</strong> @Model.EmailId</p>
    <p><strong>Mobile:</strong> @Model.MobileNo</p>
    <p><strong>Designation:</strong> @Model.Designation</p>
}
else if (Context.Request.Query.ContainsKey("id"))
{
    <p style="color:red;">Contact not found</p>
}

<br />
<a asp-action="ShowContacts" class="btn btn-secondary">Back to List</a>