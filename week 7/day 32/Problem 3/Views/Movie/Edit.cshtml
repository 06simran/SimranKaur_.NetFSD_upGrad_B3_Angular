@model WebApplication11.Models.Movie
@{ ViewData["Title"] = "Edit Movie"; }

<h2 class="mb-4">Edit Movie</h2>

<div class="card" style="max-width:550px;">
    <div class="card-body">
        <form method="post" action="/Movie/Edit">
            <input type="hidden" name="Id" value="@Model.Id" />
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input type="text" name="Title" class="form-control" value="@Model.Title" />
                @Html.ValidationMessageFor(m => m.Title, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                <label class="form-label">Genre</label>
                <input type="text" name="Genre" class="form-control" value="@Model.Genre" />
                @Html.ValidationMessageFor(m => m.Genre, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                <label class="form-label">Release Date</label>
                <input type="date" name="ReleaseDate" class="form-control"
                       value="@Model.ReleaseDate.ToString("yyyy-MM-dd")" />
                @Html.ValidationMessageFor(m => m.ReleaseDate, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                <label class="form-label">Price (₹)</label>
                <input type="number" step="0.01" name="Price" class="form-control" value="@Model.Price" />
                @Html.ValidationMessageFor(m => m.Price, "", new { @class = "text-danger" })
            </div>
            <div class="mb-3">
                <label class="form-label">Rating</label>
                <select name="Rating" class="form-control">
                    <option value="">-- Select Rating --</option>
                    <option value="G" selected="@(Model.Rating == "G")">G</option>
                    <option value="PG" selected="@(Model.Rating == "PG")">PG</option>
                    <option value="PG-13" selected="@(Model.Rating == "PG-13")">PG-13</option>
                    <option value="R" selected="@(Model.Rating == "R")">R</option>
                    <option value="U" selected="@(Model.Rating == "U")">U</option>
                    <option value="UA" selected="@(Model.Rating == "UA")">UA</option>
                    <option value="A" selected="@(Model.Rating == "A")">A</option>
                </select>
                @Html.ValidationMessageFor(m => m.Rating, "", new { @class = "text-danger" })
            </div>
            <button type="submit" class="btn btn-warning">Update</button>
            <a href="/Movie/Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>