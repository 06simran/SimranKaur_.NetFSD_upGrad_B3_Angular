@model WebApplication11.Models.Movie
@{ ViewData["Title"] = "Delete Movie"; }

<h2 class="mb-4">Delete Movie</h2>

<div class="alert alert-danger" style="max-width:500px;">
    Are you sure you want to delete <strong>@Model.Title</strong>?
</div>

<div class="card" style="max-width:500px;">
    <div class="card-body">
        <table class="table table-borderless">
            <tr><th>Title</th><td>@Model.Title</td></tr>
            <tr><th>Genre</th><td>@Model.Genre</td></tr>
            <tr><th>Release Date</th><td>@Model.ReleaseDate.ToString("dd MMM yyyy")</td></tr>
            <tr><th>Price</th><td>₹@Model.Price</td></tr>
            <tr><th>Rating</th><td>@Model.Rating</td></tr>
        </table>
        <form method="post" action="/Movie/Delete/@Model.Id">
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
            <a href="/Movie/Index" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>