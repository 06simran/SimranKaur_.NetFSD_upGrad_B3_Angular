@model List<WebApplication20.Models.ContactInfo>

@{
    ViewData["Title"] = "All Contacts";
}

<h2 class="mb-4">All Contacts</h2>

@if (Model == null || Model.Count == 0)
{
    <div class="alert alert-info">No contacts found. <a href="/Contact/AddContact">Add one!</a></div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>First Name</th>
                <th>Last Name</th>
                <th>Company</th>
                <th>Email</th>
                <th>Mobile</th>
                <th>Designation</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var contact in Model)
            {
                <tr>
                    <td>@contact.ContactId</td>
                    <td>@contact.FirstName</td>
                    <td>@contact.LastName</td>
                    <td>@contact.CompanyName</td>
                    <td>@contact.EmailId</td>
                    <td>@contact.MobileNo</td>
                    <td>@contact.Designation</td>
                    <td>
                        <a href="/Contact/GetContactById/@contact.ContactId" 
                           class="btn btn-sm btn-primary">View</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}